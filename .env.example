# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Server-only (Vercel): validates API bearer tokens; prefer service role in production
SUPABASE_SERVICE_ROLE_KEY=

# NLC Logto OIDC (via Supabase custom provider)
LOGTO_ISSUER=https://sso.newlife.org.tw/oidc
LOGTO_CLIENT_ID=
LOGTO_CLIENT_SECRET=
LOGTO_OIDC_PROVIDER=custom:nlc-logto

# App URLs
APP_BASE_URL=https://your-app.vercel.app

# Member Hub server-to-server (optional in Phase 0 — identity enrichment when provisioned by NLC IT)
MEMBER_HUB_BASE_URL=https://member.newlife.org.tw
MEMBER_HUB_SERVICE_TOKEN=
MEMBER_HUB_CONTEXT_PATH=/api/integrations/bible-speed-reading/me/context
